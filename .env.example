# Copy this file to .env before running Docker Compose.
# Generate JWT_SECRET with at least 32 random characters.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# MongoDB
MONGO_DATABASE=cloud_share

# Razorpay test credentials. Leave blank only if you are not testing payments yet.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# URLs used by CORS and generated public share links.
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173
VITE_API_URL=/api

# Optional pricing overrides, in paise.
PREMIUM_PRICE_PAISE=49900
ULTIMATE_PRICE_PAISE=99900
